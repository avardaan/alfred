# Local HTTP port for the Bun server (default 3000)
PORT=3000

# Vapi API key — required for all scripts and the running server
# Get from https://dashboard.vapi.ai → API Keys
VAPI_API_KEY=

# Same value as VAPI_API_KEY — only needed for @vapi-ai/mcp-server (local dev tooling)
VAPI_TOKEN=

# Public base URL where Vapi can reach your server (ngrok, Codespaces forwarded port, etc.)
# Required before running setup:vapi or placing calls — webhooks won't work without it
# Do NOT include /webhook/vapi — the app appends that path automatically
VAPI_SERVER_URL=

# Vapi assistant UUID — printed by `bun run setup:vapi`, required for sync:assistant and test:call
VAPI_ASSISTANT_ID=

# Vapi phone number UUID — printed by `bun run setup:vapi`, required for test:call
VAPI_PHONE_NUMBER_ID=

# Preferred US area code when provisioning a new Vapi number (default 415)
VAPI_AREA_CODE=415

# Your phone number in E.164 format (e.g. +14155551234) — required for `bun run test:call`
VAPI_TEST_PHONE_NUMBER=

# Twilio number import (optional) — used by `bun run import:twilio` to use a Twilio
# number instead of a Vapi-provisioned one. Use your LIVE (not Test) credentials
# from https://console.twilio.com (Account Dashboard → Account Info).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio number you own, in E.164 format (e.g. +14155551234)
TWILIO_PHONE_NUMBER=
