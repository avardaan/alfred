# Copy to .env and fill in values.
# REQUIRED = needed by the running webhook server.
# OPTIONAL = scripts, MCP tooling, or when updating Vapi config.

# REQUIRED — Vapi assistant UUID (printed by `bun run setup:vapi`)
# Used by inbound assistant-request webhooks
VAPI_ASSISTANT_ID=

# OPTIONAL — local HTTP port (default 3000). Render sets PORT automatically.
PORT=3000

# OPTIONAL — Vapi API key; needed for setup/sync/test/import scripts (not the running server)
# Get from https://dashboard.vapi.ai → API Keys
VAPI_API_KEY=

# OPTIONAL — same as VAPI_API_KEY; only for @vapi-ai/mcp-server in Cursor
VAPI_TOKEN=

# OPTIONAL — public base URL where Vapi reaches your server; needed for setup:vapi and sync:assistant
# Do NOT include /webhook/vapi — the app appends that path automatically
VAPI_SERVER_URL=

# OPTIONAL — Vapi phone number UUID (printed by setup:vapi or import:twilio); needed for `bun run test:call`
VAPI_PHONE_NUMBER_ID=

# OPTIONAL — preferred US area code when provisioning a new Vapi number (default 415)
VAPI_AREA_CODE=415

# OPTIONAL — your phone in E.164 format; needed for `bun run test:call`
VAPI_TEST_PHONE_NUMBER=

# OPTIONAL — Twilio import (`bun run import:twilio`); use LIVE credentials from
# https://console.twilio.com (Account Dashboard → Account Info)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- ElevenLabs (migration; Vapi remains until cutover) ---

# OPTIONAL — ElevenLabs API key; scripts + CLI (`bun run elevenlabs auth login`)
# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# OPTIONAL — public base URL for webhook tools + post-call webhooks (same as VAPI_SERVER_URL during migration)
# Do NOT include paths — app uses /webhook/elevenlabs and /tools/get_weather
ELEVENLABS_SERVER_URL=

# OPTIONAL — printed by `bun run setup:elevenlabs`
ELEVENLABS_AGENT_ID=

# OPTIONAL — printed by setup/sync when weather tool is created
ELEVENLABS_WEATHER_TOOL_ID=

# OPTIONAL — printed by `bun run import:twilio:elevenlabs`
ELEVENLABS_PHONE_NUMBER_ID=
