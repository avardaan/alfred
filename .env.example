PORT=3000

# From https://dashboard.vapi.ai → API Keys
VAPI_API_KEY=

# Public URL where Vapi can reach your server (e.g. https://abc123.ngrok.io)
# Required for webhooks during setup. Do not include /webhook/vapi — that is appended automatically.
VAPI_SERVER_URL=

# Populated after running: bun run setup:vapi
VAPI_ASSISTANT_ID=
VAPI_PHONE_NUMBER_ID=

# Optional: preferred US area code for a free Vapi number
VAPI_AREA_CODE=415

# Optional: your phone number in E.164 format for outbound test calls
VAPI_TEST_PHONE_NUMBER=
