# Copy to .env and fill in values.
# OPTIONAL = scripts, MCP tooling, or CLI auth.
# The running webhook server needs DATABASE_URL (Postgres) beyond PORT.

# OPTIONAL — local HTTP port (default 3000)
PORT=3000

# REQUIRED for runtime — Postgres connection string (local or remote)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# OPTIONAL — ElevenLabs API key; used by setup/sync/test/import scripts
# Get from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# OPTIONAL — public base URL for webhook tools + init webhook
# Do NOT include paths — app uses /webhook/elevenlabs/init and /tools/get_weather
ELEVENLABS_SERVER_URL=

# OPTIONAL — printed by `bun run setup`
ELEVENLABS_AGENT_ID=

# OPTIONAL — printed by setup/sync when weather tool is created
ELEVENLABS_WEATHER_TOOL_ID=

# OPTIONAL — printed by `bun run import:twilio`
ELEVENLABS_PHONE_NUMBER_ID=

# OPTIONAL — your phone in E.164 format; needed for `bun run test:call`
ELEVENLABS_TEST_PHONE_NUMBER=

# OPTIONAL — printed by `bun run setup`; outbound agent for autonomous tasks
ELEVENLABS_OUTBOUND_AGENT_ID=

# OPTIONAL — printed by setup/sync when submit_task_result tool is created
ELEVENLABS_SUBMIT_TASK_RESULT_TOOL_ID=

# OPTIONAL — printed by setup/sync when create_task tool is created
ELEVENLABS_CREATE_TASK_TOOL_ID=

# OPTIONAL — printed by setup/sync when lookup_business tool is created
ELEVENLABS_LOOKUP_BUSINESS_TOOL_ID=

# OPTIONAL — Google Places API key; used by create_task to look up business phone numbers
# Get from https://console.cloud.google.com/google/maps-apis/credentials
# Enable "Places API (New)" on your project
GOOGLE_PLACES_API_KEY=

# OPTIONAL — Twilio import (`bun run import:twilio`); use LIVE credentials from
# https://console.twilio.com (Account Dashboard → Account Info)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
